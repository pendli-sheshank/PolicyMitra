# Copy to .env and fill in locally. Never commit .env.

DATABASE_URL=postgresql://postgres@localhost:5432/policymitra

# Optional — system runs in degraded (no-LLM) mode without any of these.
# Set LLM_PROVIDER to "anthropic" or "openrouter" to choose explicitly; if
# left blank, ANTHROPIC_API_KEY is preferred when both are set.
LLM_PROVIDER=
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# OpenRouter (https://openrouter.ai) gives one API key access to many
# providers' models (OpenAI, Google, Meta, Mistral, Anthropic, and more) —
# set OPENROUTER_MODEL to any model ID from https://openrouter.ai/models.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

VOYAGE_API_KEY=

# Retrieval / guardrail tuning
RETRIEVAL_CONF_THRESHOLD=0.35
SESSION_TTL_HOURS=24

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
