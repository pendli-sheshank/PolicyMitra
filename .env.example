# Copy to .env (never commit it), or supply real environment variables — real
# env vars (e.g. GitHub Codespaces secrets) always take precedence over .env.

# REQUIRED. Postgres with the pgvector extension. The default deployment is a
# Supabase project — use the SESSION-POOLER DSN (IPv4-friendly); the direct
# db.<project-ref>.supabase.co host is IPv6-only:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Chat LLM: Google Gemini. Without a key the system runs in degraded (no-LLM)
# mode: retrieval, comparison, recommendation, and the offline eval checks all
# still work; only generated answers/drafts return 503. LLM_PROVIDER may be
# set to "gemini" explicitly; if blank it is inferred from GEMINI_API_KEY.
LLM_PROVIDER=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Embeddings: OpenAI text-embedding-3-small (1536-dim, matches the pgvector
# column). Without a key the offline hash embedder is used (fine for dev/CI,
# not semantic). Ingest-time and query-time embedders must match — re-run
# `make ingest` after adding/removing the key.
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# Integration tests only: a DISPOSABLE Postgres database — the test suite
# drops and recreates the kb/mem/agent/audit schemas in it on every run.
TEST_DATABASE_URL=

# Retrieval / guardrail tuning
RETRIEVAL_CONF_THRESHOLD=0.35
SESSION_TTL_HOURS=24

# API rate limiting (per-IP requests/minute on /api/v1/*; 0 disables)
RATE_LIMIT_PER_MINUTE=30

# Frontend (frontend/.env.local is generated automatically by the
# devcontainer setup; set manually only for non-Codespaces custom setups)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
