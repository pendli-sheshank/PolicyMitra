# Everything in this file is OPTIONAL — PolicyMitra runs with zero env config.
# The database is an embedded SQLite file (data/policymitra.db); there are no
# servers and no credentials. Copy to .env only if you want to set any of the
# keys below. Never commit .env.
#
# In GitHub Codespaces, prefer repository/user Codespaces secrets over a .env
# file — real environment variables always take precedence over .env values.

# Override the SQLite database file location (default: data/policymitra.db)
# POLICYMITRA_DB=data/policymitra.db

# LLM keys — without any of these the system runs in degraded (no-LLM) mode:
# retrieval, comparison, recommendation, and eval all still work; only
# generated answers/drafts return 503. Set LLM_PROVIDER to "anthropic" or
# "openrouter" to choose explicitly; if left blank, ANTHROPIC_API_KEY is
# preferred when both are set.
LLM_PROVIDER=
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# OpenRouter (https://openrouter.ai) gives one API key access to many
# providers' models — set OPENROUTER_MODEL to any model ID from
# https://openrouter.ai/models.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional real embedding provider (default is the offline local embedder)
VOYAGE_API_KEY=

# Retrieval / guardrail tuning
RETRIEVAL_CONF_THRESHOLD=0.35
SESSION_TTL_HOURS=24

# API rate limiting (per-IP requests/minute on /api/v1/*; 0 disables)
RATE_LIMIT_PER_MINUTE=30

# Frontend (frontend/.env.local is generated automatically by the
# devcontainer setup; set manually only for non-Codespaces custom setups)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
